# ── Application ──────────────────────────────────────────────
APP_NAME=Hackathon Starter
APP_ENV=development
ENVIRONMENT=development
DEBUG=true
API_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000

# ── Database ─────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app
# Used when running the backend outside Docker (compose overrides host to `db`)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/app

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS (comma-separated origins) ───────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Files ────────────────────────────────────────────────────
UPLOAD_DIR=uploads

# ── URLs ─────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Seed admin user (created on first startup) ───────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin12345

# ── Frontend (NEXT_PUBLIC_* are baked in at build time) ──────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_NAME=Hackathon Starter
